# Copy to .env (auto-loaded by jobapply.py). Fill in what you use.

# Required for the bu-2-0 model (https://cloud.browser-use.com/new-api-key)
BROWSER_USE_API_KEY=

# Required only if you compare against / run gemini models
GOOGLE_API_KEY=

# Optional: other providers
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Gmail read-only OAuth for verification codes. Easiest: drop a
# gmail_credentials.json into the browser-use config dir and let the first run
# do the OAuth consent. Or pass paths on the CLI:
#   --gmail-credentials /path/gmail_credentials.json --gmail-token /path/gmail_token.json
# (Leave blank for fill-only jobs with no verification wall.)
